@model dynamic

@{
    ViewData["Title"] = "Çalışanların Departmanları";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<a asp-controller="Report"
   asp-action="Index"
   class="btn btn-primary mb-3">
    ← Raporlara Dön
</a>

<h2>Çalışanların Departmanları</h2>

<table class="table table-bordered table-striped">

    <thead>
        <tr>
            <th>Çalışan Adı Soyadı</th>
            <th>Departman</th>
        </tr>
    </thead>

    <tbody>

        @foreach (var item in Model)
        {
            <tr>
                <td>@item.FullName</td>
                <td>@item.Department</td>
            </tr>
        }

    </tbody>

</table>