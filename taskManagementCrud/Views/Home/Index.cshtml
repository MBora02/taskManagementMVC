@model taskManagementCrud.Models.viewModel.HomeDashboardVM
@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, shrink-to-fit=no" />
    <title>Kullanıcı Paneli - Görev Yönetim Sistemi</title>
    <!-- Font Awesome icons -->
    <script src="https://use.fontawesome.com/releases/v6.3.0/js/all.js" crossorigin="anonymous"></script>
    <!-- Google fonts -->
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet" />
    <!-- Bootstrap CSS CDN -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.2.3/dist/css/bootstrap.min.css" rel="stylesheet" />
    <!-- Custom theme CSS -->
    <link href="~/css/dashboard.css" rel="stylesheet" />
</head>
<body>
    <!-- Navigation -->
    <nav class="navbar navbar-expand-lg navbar-dark navbar-custom fixed-top shadow-sm">
        <div class="container px-4">
            <a class="navbar-brand d-flex align-items-center gap-2" href="@Url.Action("Index", "Home")">
                <i class="fas fa-tasks text-indigo-400"></i>
                <span>GÖREV YÖNETİMİ</span>
            </a>
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarResponsive" aria-controls="navbarResponsive" aria-expanded="false" aria-label="Toggle navigation">
                <span class="navbar-toggler-icon"></span>
            </button>
            <div class="collapse navbar-collapse" id="navbarResponsive">
                <ul class="navbar-nav ms-auto align-items-center">
                    <li class="nav-item">
                        <a class="nav-link px-3 active" href="@Url.Action("Index", "Home")">
                            <i class="fas fa-home me-1"></i> Anasayfa
                        </a>
                    </li>
                    @if (User.IsInRole("Admin"))
                    {
                        <li class="nav-item">
                            <a class="nav-link px-3" href="@Url.Action("Index", "Department")">
                                <i class="fas fa-user-shield me-1"></i> Yönetim Paneli
                            </a>
                        </li>
                    }
                    @if (User.Identity?.IsAuthenticated == true)
                    {
                        <li class="nav-item ms-lg-2 me-lg-3">
                            <span class="nav-link d-flex align-items-center gap-2 py-1 px-3 rounded-pill bg-dark bg-opacity-50 border border-secondary text-white">
                                <span class="user-avatar" style="width: 1.5rem; height: 1.5rem; font-size: 0.75rem;">
                                    @(User.Identity.Name?[..1].ToUpper() ?? "U")
                                </span>
                                <span>@User.Identity.Name</span>
                            </span>
                        </li>
                        <li class="nav-item">
                            <a class="btn btn-outline-light btn-sm rounded-pill px-3 py-1.5" href="@Url.Action("Logout", "Account")">
                                <i class="fas fa-sign-out-alt me-1"></i> Çıkış Yap
                            </a>
                        </li>
                    }
                </ul>
            </div>
        </div>
    </nav>

    <!-- Page Header -->
    <header class="dashboard-header">
        <div class="container px-4">
            <div class="row align-items-center">
                <div class="col-md-8">
                    <h1>Kullanıcı Paneli</h1>
                    <p class="lead mb-0">Hoş geldiniz, şirketin güncel görev, proje ve ekip durumunu buradan takip edebilirsiniz.</p>
                </div>
                <div class="col-md-4 text-md-end mt-3 mt-md-0">
                    <div class="badge bg-primary bg-opacity-10 border border-primary text-white rounded-pill px-3 py-2 fs-6">
                        <i class="far fa-calendar-alt me-2"></i> @DateTime.Now.ToString("dd MMMM yyyy")
                    </div>
                </div>
            </div>
        </div>
    </header>

    <!-- Main Content -->
    <main class="container px-4">
        <!-- Stats Row -->
        <div class="row g-4 mb-5">
            <div class="col-md-3 col-sm-6">
                <div class="card stat-card tasks h-100 p-4">
                    <div class="d-flex align-items-center justify-content-between">
                        <div>
                            <div class="stat-value">@Model.TotalTasks</div>
                            <div class="stat-label mt-1">Toplam Görev</div>
                        </div>
                        <div class="stat-icon">
                            <i class="fas fa-clipboard-list"></i>
                        </div>
                    </div>
                </div>
            </div>
            <div class="col-md-3 col-sm-6">
                <div class="card stat-card projects h-100 p-4">
                    <div class="d-flex align-items-center justify-content-between">
                        <div>
                            <div class="stat-value">@Model.TotalProjects</div>
                            <div class="stat-label mt-1">Aktif Proje</div>
                        </div>
                        <div class="stat-icon">
                            <i class="fas fa-project-diagram"></i>
                        </div>
                    </div>
                </div>
            </div>
            <div class="col-md-3 col-sm-6">
                <div class="card stat-card employees h-100 p-4">
                    <div class="d-flex align-items-center justify-content-between">
                        <div>
                            <div class="stat-value">@Model.TotalEmployees</div>
                            <div class="stat-label mt-1">Ekip Üyesi</div>
                        </div>
                        <div class="stat-icon">
                            <i class="fas fa-users"></i>
                        </div>
                    </div>
                </div>
            </div>
            <div class="col-md-3 col-sm-6">
                <div class="card stat-card departments h-100 p-4">
                    <div class="d-flex align-items-center justify-content-between">
                        <div>
                            <div class="stat-value">@Model.TotalDepartments</div>
                            <div class="stat-label mt-1">Departman</div>
                        </div>
                        <div class="stat-icon">
                            <i class="fas fa-sitemap"></i>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Section Navigation & Search -->
        <div class="row align-items-center mb-4 g-3">
            <div class="col-md-7">
                <ul class="nav nav-pills nav-pills-custom" id="dashboardTabs" role="tablist">
                    <li class="nav-item" role="presentation">
                        <button class="nav-link active w-100" id="tasks-tab" data-bs-toggle="tab" data-bs-target="#tasks-panel" type="button" role="tab" aria-controls="tasks-panel" aria-selected="true">
                            <i class="fas fa-check-square me-2"></i>Görevler (@Model.Tasks.Count)
                        </button>
                    </li>
                    <li class="nav-item" role="presentation">
                        <button class="nav-link w-100" id="projects-tab" data-bs-toggle="tab" data-bs-target="#projects-panel" type="button" role="tab" aria-controls="projects-panel" aria-selected="false">
                            <i class="fas fa-project-diagram me-2"></i>Projeler (@Model.Projects.Count)
                        </button>
                    </li>
                    <li class="nav-item" role="presentation">
                        <button class="nav-link w-100" id="team-tab" data-bs-toggle="tab" data-bs-target="#team-panel" type="button" role="tab" aria-controls="team-panel" aria-selected="false">
                            <i class="fas fa-user-friends me-2"></i>Ekip Arkadaşlarımız (@Model.Employees.Count)
                        </button>
                    </li>
                </ul>
            </div>
            <div class="col-md-5">
                <div class="input-group">
                    <span class="input-group-text bg-white border-end-0 text-muted">
                        <i class="fas fa-search"></i>
                    </span>
                    <input type="text" id="dashboardSearch" class="form-control border-start-0 search-control" placeholder="Tablodaki kayıtlarda ara..." />
                </div>
            </div>
        </div>

        <!-- Tab Content -->
        <div class="tab-content" id="dashboardTabContent">
            <!-- Tasks Panel -->
            <div class="tab-pane fade show active" id="tasks-panel" role="tabpanel" aria-labelledby="tasks-tab">
                <div class="card dashboard-panel">
                    <div class="panel-title">
                        <i class="fas fa-clipboard-list text-primary"></i>
                        <span>Şirket Görev Panosu</span>
                    </div>
                    <div class="table-responsive">
                        <table class="table table-custom align-middle" id="tasksTable">
                            <thead>
                                <tr>
                                    <th style="width: 80px;">#ID</th>
                                    <th>Görev Adı</th>
                                    <th>Açıklama</th>
                                    <th>Sorumlu Çalışan</th>
                                    <th>İlgili Proje</th>
                                </tr>
                            </thead>
                            <tbody>
                                @if (Model.Tasks.Any())
                                {
                                    @foreach (var task in Model.Tasks)
                                    {
                                        <tr class="searchable-row">
                                            <td><span class="text-muted fw-bold">#@task.TaskId</span></td>
                                            <td><span class="fw-semibold text-dark">@task.TaskName</span></td>
                                            <td><span class="text-muted">@(string.IsNullOrEmpty(task.TaskDescription) ? "-" : task.TaskDescription)</span></td>
                                            <td>
                                                @if (task.Employee != null)
                                                {
                                                    <span class="badge-custom employee">
                                                        <i class="far fa-user me-1"></i> @task.Employee.EmployeeName @task.Employee.EmployeeSurname
                                                    </span>
                                                }
                                                else
                                                {
                                                    <span class="text-muted">-</span>
                                                }
                                            </td>
                                            <td>
                                                @if (task.Project != null)
                                                {
                                                    <span class="badge-custom project">
                                                        <i class="fas fa-folder me-1"></i> @task.Project.ProjectName
                                                    </span>
                                                }
                                                else
                                                {
                                                    <span class="text-muted">-</span>
                                                }
                                            </td>
                                        </tr>
                                    }
                                }
                                else
                                {
                                    <tr>
                                        <td colspan="5" class="text-center py-4 text-muted">
                                            @if (User.IsInRole("Admin"))
                                            {
                                                <span>Sistemde henüz kayıtlı görev bulunmamaktadır.</span>
                                            }
                                            else
                                            {
                                                <span>Size atanmış herhangi bir görev bulunmamaktadır.</span>
                                            }
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>

            <!-- Projects Panel -->
            <div class="tab-pane fade" id="projects-panel" role="tabpanel" aria-labelledby="projects-tab">
                <div class="card dashboard-panel">
                    <div class="panel-title">
                        <i class="fas fa-project-diagram text-success"></i>
                        <span>Projeler Listesi</span>
                    </div>
                    <div class="table-responsive">
                        <table class="table table-custom align-middle" id="projectsTable">
                            <thead>
                                <tr>
                                    <th style="width: 80px;">#ID</th>
                                    <th>Proje Adı</th>
                                    <th>Açıklama</th>
                                    <th>Süre (Hafta)</th>
                                    <th>Üye Sayısı</th>
                                    <th>İlgili Departman</th>
                                    <th>Yönetici Çalışan</th>
                                </tr>
                            </thead>
                            <tbody>
                                @if (Model.Projects.Any())
                                {
                                    @foreach (var proj in Model.Projects)
                                    {
                                        <tr class="searchable-row">
                                            <td><span class="text-muted fw-bold">#@proj.ProjectId</span></td>
                                            <td><span class="fw-semibold text-dark">@proj.ProjectName</span></td>
                                            <td><span class="text-muted">@(string.IsNullOrEmpty(proj.ProjectDescription) ? "-" : proj.ProjectDescription)</span></td>
                                            <td>
                                                <span class="badge bg-light text-dark border rounded-pill px-2 py-1">
                                                    <i class="far fa-clock me-1 text-primary"></i> @proj.ProjectTotalWeek Hafta
                                                </span>
                                            </td>
                                            <td>
                                                <span class="badge bg-light text-dark border rounded-pill px-2 py-1">
                                                    <i class="fas fa-users me-1 text-info"></i> @proj.ProjectUserCount Kişi
                                                </span>
                                            </td>
                                            <td>
                                                @if (proj.Department != null)
                                                {
                                                    <span class="badge-custom department">
                                                        <i class="fas fa-sitemap me-1"></i> @proj.Department.DepartmentName
                                                    </span>
                                                }
                                                else
                                                {
                                                    <span class="text-muted">-</span>
                                                }
                                            </td>
                                            <td>
                                                @if (proj.Employee != null)
                                                {
                                                    <span class="badge-custom employee">
                                                        <i class="far fa-user me-1"></i> @proj.Employee.EmployeeName @proj.Employee.EmployeeSurname
                                                    </span>
                                                }
                                                else
                                                {
                                                    <span class="text-muted">-</span>
                                                }
                                            </td>
                                        </tr>
                                    }
                                }
                                else
                                {
                                    <tr>
                                        <td colspan="7" class="text-center py-4 text-muted">
                                            @if (User.IsInRole("Admin"))
                                            {
                                                <span>Sistemde henüz kayıtlı proje bulunmamaktadır.</span>
                                            }
                                            else
                                            {
                                                <span>Size atanmış veya yöneticisi olduğunuz herhangi bir proje bulunmamaktadır.</span>
                                            }
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>

            <!-- Team Panel -->
            <div class="tab-pane fade" id="team-panel" role="tabpanel" aria-labelledby="team-tab">
                <div class="card dashboard-panel">
                    <div class="panel-title">
                        <i class="fas fa-users text-info"></i>
                        <span>Çalışan Kadromuz</span>
                    </div>
                    <div class="table-responsive">
                        <table class="table table-custom align-middle" id="employeesTable">
                            <thead>
                                <tr>
                                    <th style="width: 80px;">#ID</th>
                                    <th>Adı Soyadı</th>
                                    <th>Yaş</th>
                                    <th>Cinsiyet</th>
                                    <th>Telefon No</th>
                                    <th>Departman</th>
                                </tr>
                            </thead>
                            <tbody>
                                @if (Model.Employees.Any())
                                {
                                    @foreach (var emp in Model.Employees)
                                    {
                                        <tr class="searchable-row">
                                            <td><span class="text-muted fw-bold">#@emp.EmployeId</span></td>
                                            <td><span class="fw-semibold text-dark">@emp.EmployeeName @emp.EmployeeSurname</span></td>
                                            <td>@emp.EmployeeAge</td>
                                            <td>
                                                <span class="badge bg-light text-dark border px-2 py-1 rounded-pill">
                                                    @(emp.EmployeeGender == "Erkek" ? "Erkek" : "Kadın")
                                                </span>
                                            </td>
                                            <td>@emp.EmployeePhone</td>
                                            <td>
                                                @if (emp.Department != null)
                                                {
                                                    <span class="badge-custom department">
                                                        <i class="fas fa-sitemap me-1"></i> @emp.Department.DepartmentName
                                                    </span>
                                                }
                                                else
                                                {
                                                    <span class="text-muted">-</span>
                                                }
                                            </td>
                                        </tr>
                                    }
                                }
                                else
                                {
                                    <tr>
                                        <td colspan="6" class="text-center py-4 text-muted">Sistemde henüz kayıtlı çalışan bulunmamaktadır.</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    </main>

    <!-- Footer -->
    <footer class="border-top text-center">
        <div class="container px-4">
            <div class="row justify-content-center">
                <div class="col-md-8">
                    <ul class="list-inline mb-3">
                        <li class="list-inline-item mx-2">
                            <a href="#!" class="text-muted"><i class="fab fa-twitter fa-lg"></i></a>
                        </li>
                        <li class="list-inline-item mx-2">
                            <a href="#!" class="text-muted"><i class="fab fa-facebook-f fa-lg"></i></a>
                        </li>
                        <li class="list-inline-item mx-2">
                            <a href="#!" class="text-muted"><i class="fab fa-github fa-lg"></i></a>
                        </li>
                    </ul>
                    <div class="small text-muted">Telif Hakkı &copy; Bora Task Management @DateTime.Now.Year. Bütün Hakları Saklıdır.</div>
                </div>
            </div>
        </div>
    </footer>

    <!-- Bootstrap core JS -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.2.3/dist/js/bootstrap.bundle.min.js"></script>
    
    <!-- Client-Side Search Filtering -->
    <script>
        document.getElementById('dashboardSearch').addEventListener('keyup', function () {
            let filterValue = this.value.toLowerCase();
            
            // Get all rows from active panel table
            let activePanel = document.querySelector('.tab-pane.active');
            let rows = activePanel.querySelectorAll('.searchable-row');
            
            rows.forEach(function (row) {
                let text = row.textContent.toLowerCase();
                if (text.includes(filterValue)) {
                    row.style.display = '';
                } else {
                    row.style.display = 'none';
                }
            });
        });

        // Clear search input when switching tabs
        let tabButtons = document.querySelectorAll('button[data-bs-toggle="tab"]');
        tabButtons.forEach(button => {
            button.addEventListener('shown.bs.tab', function () {
                let searchInput = document.getElementById('dashboardSearch');
                searchInput.value = '';
                
                // Show all rows again in newly activated panel
                let activePanel = document.querySelector('.tab-pane.active');
                let rows = activePanel.querySelectorAll('.searchable-row');
                rows.forEach(row => row.style.display = '');
            });
        });
    </script>
</body>
</html>
