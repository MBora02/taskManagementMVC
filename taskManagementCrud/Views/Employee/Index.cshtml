
@model List<taskManagementCrud.Models.Employee>

@{
    ViewData["Title"] = "Employees";
}

<h1>Employees List</h1>

<a asp-action="Create" class="btn btn-primary mb-3">Create New Employee</a>

<table class="table table-striped table-bordered">
    <thead>
        <tr>
            <th>Name</th>
            <th>Surname</th>
            <th>Age</th>
            <th>Gender</th>
            <th>Phone</th>
            <th>Department</th>
            <th>Actions</th>
        </tr>
    </thead>

    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>@item.EmployeeName</td>
                <td>@item.EmployeeSurname</td>
                <td>@item.EmployeeAge</td>
                <td>@item.EmployeeGender</td>
                <td>@item.EmployeePhone</td>
                <td>@item.Department?.DepartmentName</td>

                <td>
                    <a asp-action="Edit" asp-route-id="@item.EmployeId" class="btn btn-success btn-sm">
                        Edit
                    </a>

                    <a asp-action="Delete" asp-route-id="@item.EmployeId" class="btn btn-danger btn-sm">
                        Delete
                    </a>
                </td>
            </tr>
        }
    </tbody>
</table>