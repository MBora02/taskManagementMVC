@model List<taskManagementCrud.Models.TaskItem>

<h1>Task List</h1>

<a asp-action="Create" class="btn btn-primary mb-3">
    Create New Task
</a>

<table class="table table-bordered">
    <thead>
        <tr>
            <th>Task Name</th>
            <th>Description</th>
            <th>Employee</th>
            <th>Project</th>
            <th>Actions</th>
        </tr>
    </thead>

    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>@item.TaskName</td>
                <td>@item.TaskDescription</td>
                <td>@item.Employee?.EmployeeName</td>
                <td>@item.Project?.ProjectName</td>

                <td>
                    <a asp-action="Edit"
                       asp-route-id="@item.TaskId"
                       class="btn btn-success btn-sm">
                        Edit
                    </a>

                    <a asp-action="Delete"
                       asp-route-id="@item.TaskId"
                       class="btn btn-danger btn-sm">
                        Delete
                    </a>
                </td>
            </tr>
        }
    </tbody>
</table>