@model taskManagementCrud.Models.TaskItem

<h1>Edit Task</h1>

<form asp-action="Edit" method="post">

    <input type="hidden" asp-for="TaskId" />

    <div class="form-group">
        <label asp-for="TaskName"></label>
        <input asp-for="TaskName" class="form-control" />
    </div>

    <div class="form-group">
        <label asp-for="TaskDescription"></label>
        <input asp-for="TaskDescription" class="form-control" />
    </div>

    <div class="form-group">
        <label asp-for="EmployeeId"></label>
        <select asp-for="EmployeeId"
                asp-items="ViewBag.Employees"
                class="form-control">
        </select>
    </div>

    <div class="form-group">
        <label asp-for="ProjectId"></label>
        <select asp-for="ProjectId"
                asp-items="ViewBag.Projects"
                class="form-control">
        </select>
    </div>

    <br />

    <button type="submit" class="btn btn-success">
        Update
    </button>
</form>